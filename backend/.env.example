PORT=5000
MONGODB_URI=your_mongodb_atlas_uri

# ─── GROQ API (FREE) ─────────────────────────────────────────────────
# Sign up FREE at: https://console.groq.com
# Click "API Keys" -> "Create API Key" -> Copy it here
# All models below are FREE with this key (rate limited generously)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── FIREBASE ────────────────────────────────────────────────────────
# Get from Firebase Console -> Project Settings -> Service Account -> Generate Key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ─── GMAIL SMTP (FREE - for sending OTP emails) ──────────────────────
# Step 1: Use your own Gmail account
# Step 2: Go to https://myaccount.google.com/security
# Step 3: Enable "2-Step Verification" (required)
# Step 4: Go to https://myaccount.google.com/apppasswords
# Step 5: Select "Mail" + "Other" -> name it "PRAVIX AI" -> click Generate
# Step 6: Copy the 16-character password shown (e.g. abcd efgh ijkl mnop)
GMAIL_USER=yourname@gmail.com
GMAIL_APP_PASSWORD=abcdefghijklmnop

FRONTEND_URL=http://localhost:3000
